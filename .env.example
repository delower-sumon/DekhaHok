# Copy this to .env and fill in your values
# Never commit .env to git

DB_HOST=localhost
DB_PORT=3306
DB_NAME=dekhahok
DB_USER=dekhahok_user
DB_PASSWORD=your_strong_password_here

# Admin dashboard protection key — use a long random string
# Generate one: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SECRET_KEY=change_this_to_a_long_random_string
