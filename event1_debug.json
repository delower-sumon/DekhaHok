    "\u0995\u09ac\u09bf\u09a4\u09be \u09ac\u09be \u0997\u09be\u09a8 \u09b6\u09c7\u09df\u09be\u09b0 \u0995\u09b0\u09a4\u09c7 \u09aa\u09be\u09b0\u09ac\u09c7\u09a8\u0964\n\n\u09ea. \u0986\u099c\u09c0\u09ac\u09a8 \u09ae\u09c7\u09ae\u09cd\u09ac\u09be\u09b0\u09b6\u09bf\u09aa \u098f\u09ac\u0982 \u09a8\u09c7\u099f\u0993\u09df\u09be\u09b0\u09cd\u0995\u09bf\u0982: \u098f\u0987 \u09b8\u09be\u09b0\u09cd\u0995\u09c7\u09b2\u09c7 \u09af\u09c1\u0995\u09cd\u09a4 \u09b9\u0993\u09df\u09be \u09ae\u09be\u09a8\u09c7\u0987 '\u09a6\u09c7\u0996\u09be \u09b9\u09cb\u0995'-\u098f\u09b0 \u0985\u09ab\u09bf\u09b6\u09bf\u09df\u09be\u09b2 \u0995\u09ae\u09bf\u0989\u09a8\u09bf\u099f\u09bf \u09b8\u09be\u09b0\u09cd\u0995\u09c7\u09b2\u09c7\u09b0 \u0985\u0982\u09b6 \u09b9\u09df\u09c7 \u09af\u09be\u0993\u09df\u09be\u0964 \u0987\u09ad\u09c7\u09a8\u09cd\u099f \u09b6\u09c7\u09b7 \u09b9\u09b2\u09c7\u0993 \u09ae\u09c7\u09ae\u09cd\u09ac\u09be\u09b0\u09a6\u09c7\u09b0 \u09b8\u09be\u09a5\u09c7 \u09af\u09cb\u0997\u09be\u09af\u09cb\u0997 \u09a7\u09b0\u09c7 \u09b0\u09be\u0996\u09be\u09b0 \u099c\u09a8\u09cd\u09af \u09a5\u09be\u0995\u09ac\u09c7 \u09ac\u09bf\u09b6\u09c7\u09b7 \u0997\u09cd\u09b0\u09c1\u09aa \u098f\u0995\u09cd\u09b8\u09c7\u09b8\u0964\n\n\u09eb. \u09ae\u09c7\u09ae\u09cb\u09b0\u09bf \u09ab\u099f\u09cb: \u09ae\u09c1\u09b9\u09c2\u09b0\u09cd\u09a4\u099f\u09bf \u09b8\u09cd\u09ae\u09b0\u09a3\u09c0\u09df \u0995\u09b0\u09c7 \u09b0\u09be\u0996\u09a4\u09c7 \u09a5\u09be\u0995\u09ac\u09c7 \u0997\u09cd\u09b0\u09c1\u09aa \u09ab\u099f\u09cb\u09b8\u09c7\u09b6\u09a8",
